LLM_PROVIDER=gemini

# FP5 answer generation uses Gemini. Keep the real key only in the ignored .env.
LLM_API_KEY=
LLM_CHAT_MODEL=gemini-2.5-flash
LLM_TEMPERATURE=0.0
LLM_TOP_P=0.9
RETRIEVAL_TOP_K=3
LLM_EMBEDDING_MODEL=all-MiniLM-L6-v2

# FP5 uses Chroma's local all-MiniLM-L6-v2 embedding model by default.
EMBEDDING_MODEL=all-MiniLM-L6-v2
CHUNK_SIZE=800
CHUNK_OVERLAP=100

# Optional provider-specific keys if the implementation supports multiple providers.
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=llm_rag_evals
DB_USER=root
DB_PASSWORD=replace_with_local_password

CHROMA_PATH=rag/chroma
CHROMA_COLLECTION=metrostate_documents
